# Ethereum Mainnet RPC URL
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Private key for deployment (without 0x prefix)
# ⚠️ NEVER commit the actual private key to version control
PRIVATE_KEY=your_private_key_here

# Etherscan API Key for contract verification
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Optional: CoinMarketCap API Key for gas reporting
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key_here

# Enable gas reporting
GAS_REPORT_ENABLED=false

# Enable forking for testing
FORKING=false

# ============= ARBITRAGE PARAMETERS =============

# Base asset to arbitrage (e.g., WETH address)
BASE_ASSET=0xC02aaA39b223FE8D0A0e8e4F27ead9083C756Cc2

# Intermediate token for arbitrage (e.g., DAI)
INTERMEDIATE_TOKEN=0x6B175474E89094C44Da98b954EedeAC495271d0F

# Minimum profit threshold in percentage
MIN_PROFIT_THRESHOLD=0.5

# DEX routers
ROUTER_A=0x7a250d5630B4cF539739dF2C5dAcb4c659F2488D
ROUTER_B=0xd9e1cE17f2641f24aE31b8eC6c6EB8da912F8a7

# ============= CONTRACT ADDRESSES =============

# Aave V3 Pool Address Provider
AAVE_POOL_PROVIDER=0x2f39d218133AFaB8F2B819B1066c7E434Ad94E9e

# Uniswap V2 Router (default)
UNISWAP_V2_ROUTER=0x7a250d5630B4cF539739dF2C5dAcb4c659F2488D

# SushiSwap Router
SUSHISWAP_ROUTER=0xd9e1cE17f2641f24aE31b8eC6c6EB8da912F8a7

# Balancer Vault
BALANCER_VAULT=0xBA12222222228d8Ba445958a75a0704d566BF2C8
